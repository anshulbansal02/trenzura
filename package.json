{
  "name": "trenzura",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "imports": {
    "#/*": "./src/*",
    "#shared/*": "./shared/*"
  },
  "scripts": {
    "dev": "PORTLESS_TLD=localhost PORTLESS_HTTPS=0 PORTLESS_PORT=80 portless trenzura --app-port 37149 pnpm run dev:app",
    "dev:app": "vite dev",
    "sync:products": "tsx scripts/sync-products.ts",
    "sync:images:r2": "tsx scripts/sync-drive-images-to-r2.ts",
    "sync:images:manifest": "tsx scripts/sync-drive-images-to-r2.ts --manifest-only",
    "sync:images:r2:upload": "tsx scripts/sync-drive-images-to-r2.ts --upload-manifest",
    "validate:catalog-assets": "tsx scripts/validate-catalog-assets.ts",
    "publish:catalog": "pnpm sync:images:manifest && pnpm sync:products && pnpm validate:catalog-assets && pnpm sync:images:r2:upload && tsx scripts/sync-products-to-supabase.ts",
    "prepare:generated": "tsx scripts/ensure-generated-catalog.ts",
    "pretypecheck": "pnpm prepare:generated",
    "typecheck": "tsc --noEmit",
    "prebuild:ci": "pnpm prepare:generated",
    "build:ci": "vite build",
    "prebuild": "pnpm prepare:generated",
    "build": "vite build",
    "preview": "PORTLESS_TLD=localhost PORTLESS_HTTPS=0 PORTLESS_PORT=80 portless preview.trenzura --app-port 39217 pnpm run preview:app",
    "preview:app": "vite preview",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@orama/orama": "^3.1.18",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "googleapis": "^171.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "portless": "^0.13.0",
    "sharp": "0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "sharp",
      "workerd"
    ]
  }
}
